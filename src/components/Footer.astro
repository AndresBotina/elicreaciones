---
import { CONFIG } from '../config.js';
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <p class="footer__tagline">Hecho a mano en Mocoa, Putumayo, Colombia,<br/>con amor, tradición y dedicación en cada puntada.</p>
    </div>

    <nav class="footer__nav" aria-label="Navegación del pie de página">
      <ul class="footer__nav-list">
        <li><a href="/" class="footer__nav-link">Inicio</a></li>
        <li><a href="/catalogo" class="footer__nav-link">Catálogo</a></li>
        <li><a href="/nosotras" class="footer__nav-link">Nosotras</a></li>
        <li><a href="/contacto" class="footer__nav-link">Contacto</a></li>
      </ul>
    </nav>

    <div class="footer__social">
      <a
        href={CONFIG.social.instagram}
        target="_blank"
        rel="noopener noreferrer"
        class="footer__social-link"
        aria-label="Visitar Instagram de Eli Creaciones"
      >
        Instagram
      </a>
      <a
        href={CONFIG.social.facebook}
        target="_blank"
        rel="noopener noreferrer"
        class="footer__social-link"
        aria-label="Visitar Facebook de Eli Creaciones"
      >
        Facebook
      </a>
      <a
        href={CONFIG.social.tiktok}
        target="_blank"
        rel="noopener noreferrer"
        class="footer__social-link"
        aria-label="Visitar TikTok de Eli Creaciones"
      >
        TikTok
      </a>
    </div>
  </div>

  <div class="footer__bottom">
    <p>© 2025 Eli Creaciones · Hecho a mano en Mocoa, Colombia · Todos los derechos reservados</p>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-accent);
    color: var(--color-light);
    margin-top: var(--space-6);
    border-radius: 60px 60px 0 0;
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: var(--space-12);
    align-items: start;
    padding-block: var(--space-12);
  }

  .footer__logo {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-base);
    display: block;
    margin-bottom: var(--space-2);
  }

  .footer__tagline {
    font-family: var(--font-handwritten);
    font-size: var(--text-3xl);
    color: var(--color-base);
  }

  .footer__nav-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer__nav-link {
    font-family: var(--font-handwritten);
    font-size: var(--text-lg);
    color: var(--color-base);
    transition: color 0.2s;
  }

  .footer__nav-link:hover {
    color: var(--color-light);
  }

  .footer__social {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer__social-link {
    font-family: var(--font-handwritten);
    font-size: var(--text-lg);
    color: var(--color-base);
    transition: color 0.2s;
  }

  .footer__social-link:hover {
    color: var(--color-light);
  }

  .footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-block: var(--space-4);
    text-align: center;
  }

  .footer__bottom p {
    font-size: var(--text-xs);
    color: var(--color-mid);
  }

  @media (max-width: 768px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: var(--space-8);
      text-align: center;
      justify-items: center;
    }

    .footer__social {
      flex-direction: row;
      justify-content: center;
      gap: var(--space-6);
    }
  }
</style>
