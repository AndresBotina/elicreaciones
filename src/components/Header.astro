---
import { CONFIG } from '../config.js';

const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/catalogo', label: 'Catálogo' },
  { href: '/nosotras', label: 'Nosotras' },
  { href: '/contacto', label: 'Contacto' },
];

const currentPath = Astro.url.pathname;
---

<header class="header">
  <div class="container header__inner">
    <a href="/" class="header__logo" aria-label="Ir al inicio de Eli Creaciones">
      <img src="/favicon.svg" alt="" class="header__logo-icon" />
      {CONFIG.site.name}
    </a>

    <button class="header__menu-btn" aria-label="Abrir menú" aria-expanded="false" aria-controls="nav-menu">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav id="nav-menu" class="header__nav" aria-label="Navegación principal">
      <ul class="header__nav-list">
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={['header__nav-link', { 'header__nav-link--active': currentPath === href }]}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: var(--space-4);
    z-index: 100;
    background-color: var(--color-accent);
    margin-inline: auto;
    width: calc(100% - var(--space-12));
    max-width: 1200px;
    border-radius: 100px; /* Estilo píldora completo */
    box-shadow: 0 4px 20px rgba(181, 101, 118, 0.2);
    padding-inline: var(--space-8);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px; /* Grosor aumentado ligeramente */
  }

  .header__logo {
    font-family: var(--font-handwritten);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-base);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .header__logo-icon {
    width: 32px;
    height: 32px;
  }

  .header__nav-list {
    list-style: none;
    display: flex;
    gap: var(--space-8);
  }

  .header__nav-link {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-light);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: color 0.2s;
    padding-bottom: var(--space-1);
  }

  .header__nav-link:hover,
  .header__nav-link--active {
    color: var(--color-base);
  }

  .header__menu-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    padding: var(--space-2);
    cursor: pointer;
  }

  .header__menu-btn span {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--color-base);
    transition: transform 0.2s, opacity 0.2s;
  }

  @media (max-width: 768px) {
    .header__menu-btn {
      display: flex;
    }

    .header__nav {
      position: absolute;
      top: calc(100% + var(--space-3));
      left: 0;
      right: 0;
      background-color: var(--color-accent);
      border-radius: 24px;
      padding: var(--space-6);
      box-shadow: 0 8px 24px rgba(107, 53, 71, 0.2);
      opacity: 0;
      visibility: hidden;
      transform: translateY(-8px);
      transition: opacity 0.25s ease, transform 0.25s ease, visibility 0s linear 0.25s;
    }

    .header__nav.is-open {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
      transition: opacity 0.25s ease, transform 0.25s ease, visibility 0s;
    }

    .header__nav-list {
      flex-direction: column;
      gap: var(--space-5);
      align-items: center;
    }

    .header__nav-link {
      font-size: var(--text-lg);
    }
  }
</style>

<script>
  const menuBtn = document.querySelector('.header__menu-btn');
  const nav = document.querySelector('.header__nav');

  menuBtn?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('is-open');
    menuBtn.setAttribute('aria-expanded', String(!!isOpen));
  });

  document.addEventListener('click', (e) => {
    if (!nav?.contains(e.target) && !menuBtn?.contains(e.target)) {
      nav?.classList.remove('is-open');
      menuBtn?.setAttribute('aria-expanded', 'false');
    }
  });
</script>
