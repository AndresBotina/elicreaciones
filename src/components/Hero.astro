---
import WhatsAppButton from './WhatsAppButton.astro';
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__content">
      <p class="hero__eyebrow">Hecho a mano en Mocoa, Colombia</p>
      <h1 class="hero__title">Cada puntada cuenta una historia</h1>
      <p class="hero__subtitle">
        Piezas únicas a crochet hechas con dedicación y amor. Bolsos, llaveros, blusas, moñas y mucho más.
      </p>
      <div class="hero__actions">
        <a href="/catalogo" class="btn btn-primary">
          Ver catálogo →
        </a>
        <WhatsAppButton label="Pedir por WhatsApp" />
      </div>
    </div>
    <div class="hero__image">
      <div class="hero__image-placeholder" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" width="120" height="120" fill="var(--color-mid)" aria-hidden="true">
          <path d="M100 30 C65 30, 40 55, 40 90 C40 125, 65 150, 100 150 C135 150, 160 125, 160 90 C160 55, 135 30, 100 30 Z M85 75 C85 67, 92 60, 100 60 C108 60, 115 67, 115 75 C115 83, 108 90, 100 90 C92 90, 85 83, 85 75 Z M60 130 C63 110, 80 98, 100 98 C120 98, 137 110, 140 130 C127 143, 114 150, 100 150 C86 150, 73 143, 60 130 Z"/>
        </svg>
        <span>Foto próximamente</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: var(--space-24);
    background-color: var(--bg);
    overflow: hidden;
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  .hero__eyebrow {
    font-family: var(--font-handwritten);
    font-size: var(--text-lg);
    font-weight: 400;
    letter-spacing: 0.01em;
    color: var(--color-mid);
    margin-bottom: var(--space-4);
  }

  .hero__title {
    font-size: var(--text-5xl);
    font-weight: 700;
    line-height: 1.1;
    color: var(--text);
    margin-bottom: var(--space-6);
  }

  .hero__subtitle {
    font-size: var(--text-lg);
    color: var(--text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-8);
    max-width: 480px;
  }

  .hero__actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .hero__image {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero__image-placeholder {
    width: 100%;
    aspect-ratio: 4 / 5;
    max-width: 420px;
    background-color: var(--color-light);
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  @media (max-width: 768px) {
    .hero {
      padding-block: var(--space-16);
    }

    .hero__inner {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .hero__title {
      font-size: var(--text-4xl);
    }

    .hero__image {
      order: -1;
    }

    .hero__image-placeholder {
      max-width: 100%;
      aspect-ratio: 3 / 2;
    }
  }
</style>
