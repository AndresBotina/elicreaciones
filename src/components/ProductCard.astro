---
import WhatsAppButton from './WhatsAppButton.astro';
import { CONFIG } from '../config.js';

const { producto } = Astro.props;

const precio = new Intl.NumberFormat('es-CO', {
  style: 'currency',
  currency: 'COP',
  maximumFractionDigits: 0,
}).format(producto.precio);

const whatsappMessage = `Hola! Vi tu página web y me interesa el/la ${producto.nombre}. ¿Está disponible?`;
const imagenUrl = producto.imagenes?.[0];
---

<article class="product-card">
  <div class="product-card__image-wrapper">
    {imagenUrl ? (
      <img
        src={imagenUrl}
        alt={`${producto.nombre} — Eli Creaciones`}
        class="product-card__image"
        loading="lazy"
      />
    ) : (
      <div class="product-card__no-image" aria-label="Foto próximamente">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="40" height="40" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <path d="M21 15l-5-5L5 21"/>
        </svg>
        <span>Foto próximamente</span>
      </div>
    )}
    {!producto.disponible && (
      <div class="product-card__badge">No disponible</div>
    )}
  </div>

  <div class="product-card__body">
    <h3 class="product-card__name">{producto.nombre}</h3>
    <p class="product-card__description">{producto.descripcion}</p>
    <p class="product-card__price">{precio}</p>

    {producto.disponible ? (
      <WhatsAppButton message={whatsappMessage} label="Pedir por WhatsApp" />
    ) : (
      <p class="product-card__unavailable">
        Por el momento no disponible — escríbenos si te interesa
      </p>
    )}
  </div>
</article>

<style>
  .product-card {
    background-color: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 1px 4px rgba(107, 53, 71, 0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .product-card:hover {
    transform: rotate(-1deg) scale(1.02);
    box-shadow: 0 8px 24px rgba(107, 53, 71, 0.12);
  }

  .product-card__image-wrapper {
    position: relative;
    overflow: hidden;
    background-color: var(--color-light);
  }

  .product-card__image {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.3s ease;
  }

  .product-card:hover .product-card__image {
    transform: scale(1.03);
  }

  .product-card__no-image {
    width: 100%;
    min-height: 200px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  .product-card__badge {
    position: absolute;
    top: var(--space-3);
    left: var(--space-3);
    background-color: var(--color-mid);
    color: white;
    font-size: var(--text-xs);
    font-weight: 600;
    padding: var(--space-1) var(--space-3);
    border-radius: 9999px;
  }

  .product-card__body {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }

  .product-card__name {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--text);
  }

  .product-card__description {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.5;
    flex: 1;
  }

  .product-card__price {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-accent);
  }

  .product-card__unavailable {
    font-size: var(--text-xs);
    color: var(--text-muted);
    font-style: italic;
  }
</style>
