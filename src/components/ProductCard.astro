---
import WhatsAppButton from './WhatsAppButton.astro';

interface Producto {
  id: string;
  nombre: string;
  categoria: string;
  precio: number;
  moneda: string;
  descripcion: string;
  colores?: string[];
  imagenes?: string[];
  disponible: boolean;
  destacado: boolean;
}

const { producto } = Astro.props as { producto: Producto };

const precio = new Intl.NumberFormat('es-CO', {
  style: 'currency',
  currency: producto.moneda || 'COP',
  maximumFractionDigits: 0,
}).format(producto.precio);

const whatsappMessage = encodeURIComponent(
  `¡Hola! Vi tu página web y me interesa el/la ${producto.nombre}. ¿Está disponible?`
);
---

<article class="product-card">
  <div class="product-card__image-wrapper">
    {producto.imagenes && producto.imagenes.length > 0 ? (
      <div class="product-card__collage" data-count={producto.imagenes.length}>
        {producto.imagenes.map((img, index) => (
          <img
            src={img}
            alt={`${producto.nombre} — Vista ${index + 1}`}
            class={`product-card__collage-img img-${index}`}
            loading="lazy"
          />
        ))}
      </div>
    ) : (
      <div class="product-card__no-image" aria-label="Foto próximamente">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="40" height="40" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <path d="M21 15l-5-5L5 21"/>
        </svg>
        <span>Foto próximamente</span>
      </div>
    )}
    {!producto.disponible && (
      <div class="product-card__badge">No disponible</div>
    )}

    <div class="product-card__footer">
      <p class="product-card__price">{precio}</p>
      {producto.disponible ? (
        <WhatsAppButton message={whatsappMessage} label="" />
      ) : (
        <p class="product-card__unavailable">Agotado</p>
      )}
    </div>
  </div>

  <div class="product-card__body">
    <h3 class="product-card__name">{producto.nombre}</h3>
    <p class="product-card__description">{producto.descripcion}</p>
  </div>
</article>
