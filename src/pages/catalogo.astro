---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductGrid from '../components/ProductGrid.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { CONFIG } from '../config.js';
import todosLosProductos from '../data/productos.json';

const categorias = [
  { id: 'todos', label: 'Todos' },
  { id: 'bolsos', label: 'Bolsos' },
  { id: 'llaveros', label: 'Llaveros' },
  { id: 'blusas', label: 'Blusas' },
  { id: 'moñas', label: 'Moñas' },
  { id: 'amigurumis', label: 'Amigurumis' },
  { id: 'manualidades', label: 'Manualidades' },
];
---

<BaseLayout
  title="Catálogo"
  description="Explora el catálogo de Eli Creaciones. Piezas a crochet hechas a mano: bolsos, llaveros, blusas, moñas, amigurumis y manualidades. Personalizaciones disponibles."
>
  <div class="catalogo-page">
    <div class="container">
      <header class="catalogo-page__header reveal">
        <h1 class="catalogo-page__title">Nuestras <em>creaciones</em></h1>
        <p class="catalogo-page__subtitle">
          Todas las piezas son hechas a mano y se pueden personalizar. ¿No encuentras lo que buscas? Escríbenos.
        </p>
      </header>

      <div class="catalogo-page__filters reveal" role="tablist" aria-label="Filtrar por categoría">
        {categorias.map((cat) => (
          <button
            class="filter-btn"
            role="tab"
            data-categoria={cat.id}
            aria-selected={cat.id === 'todos' ? 'true' : 'false'}
          >
            {cat.label}
          </button>
        ))}
      </div>

      <div id="productos-grid">
        <ProductGrid productos={todosLosProductos} />
      </div>

      <div class="catalogo-page__custom">
        <div class="catalogo-page__custom-inner">
          <h2>¿Quieres algo personalizado?</h2>
          <p>Puedo hacer piezas a tu medida, en tus colores favoritos. ¡Escríbeme y lo hablamos!</p>
          <WhatsAppButton
            message={CONFIG.whatsapp.customMessage}
            label="Encargar pieza personalizada"
          />
        </div>
      </div>
    </div>
  </div>

  <WhatsAppButton variant="floating" />
</BaseLayout>

<style>
  .catalogo-page {
    padding-block: var(--space-16);
  }

  .catalogo-page__header {
    text-align: center;
    margin-top: var(--space-8);
    margin-bottom: var(--space-12);
    background-color: #F5E4DE;
    padding: var(--space-8) var(--space-6);
    border-radius: 60px;
    max-width: 900px;
    margin-inline: auto;
  }

  .catalogo-page__title {
    font-size: var(--text-5xl);
    font-weight: 700;
    margin-bottom: var(--space-4);
  }

  .catalogo-page__subtitle {
    font-size: var(--text-lg);
    color: var(--text-muted);
    max-width: 600px;
    margin-inline: auto;
  }

  .catalogo-page__filters {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: var(--space-12);
  }

  .filter-btn {
    padding: var(--space-2) var(--space-6);
    border-radius: 9999px;
    border: 2px solid var(--color-light);
    background-color: transparent;
    color: var(--text);
    font-size: var(--text-sm);
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.2s, border-color 0.2s, color 0.2s;
  }

  .filter-btn:hover,
  .filter-btn[aria-selected="true"] {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    color: white;
  }

  .catalogo-page__custom {
    margin-top: var(--space-24);
    padding: var(--space-12);
    background-color: var(--bg-secondary);
    border-radius: 60px;
    max-width: 1200px;
    margin-inline: auto;
    width: calc(100% - var(--space-4));
    text-align: center;
  }

  .catalogo-page__custom-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    max-width: 540px;
    margin-inline: auto;
  }

  .catalogo-page__custom h2 {
    font-size: var(--text-2xl);
    color: #8B4354; /* Título ahora más oscuro */
  }

  .catalogo-page__custom p {
    color: var(--color-accent); /* Texto ahora con el color de acento */
    font-weight: 500;
  }
</style>

<script>
  import todosLosProductos from '../data/productos.json';

  const filterBtns = document.querySelectorAll('.filter-btn');
  const grid = document.getElementById('productos-grid');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterBtns.forEach((b) => b.setAttribute('aria-selected', 'false'));
      btn.setAttribute('aria-selected', 'true');

      const categoria = btn.getAttribute('data-categoria');
      const filtrados = categoria === 'todos'
        ? todosLosProductos
        : todosLosProductos.filter((p) => p.categoria === categoria);

      renderGrid(filtrados);
    });
  });

  function renderGrid(productos) {
    if (productos.length === 0) {
      grid.innerHTML = '<div class="product-grid__empty" style="text-align:center;padding:4rem 0;color:var(--text-muted);font-size:1.125rem;">No hay productos en esta categoría todavía.</div>';
      return;
    }

    const items = productos.map((p) => {
      const precio = new Intl.NumberFormat('es-CO', {
        style: 'currency',
        currency: 'COP',
        maximumFractionDigits: 0,
      }).format(p.precio);

      const collageHtml = p.imagenes && p.imagenes.length > 0
        ? `<div class="product-card__collage" data-count="${p.imagenes.length}">
            ${p.imagenes.map((img, i) => `<img src="${img}" alt="${p.nombre} — Vista ${i+1}" class="product-card__collage-img img-${i}" loading="lazy">`).join('')}
          </div>`
        : `<div class="product-card__no-image" aria-label="Foto próximamente"><span>Foto próximamente</span></div>`;
      const whatsappMsg = encodeURIComponent(`Hola! Vi tu página web y me interesa el/la ${p.nombre}. ¿Está disponible?`);
      const waNumber = '573142501765';

      const badgeHtml = !p.disponible ? '<div class="product-card__badge">No disponible</div>' : '';

      const imageLinkHtml = p.disponible
        ? `<a href="https://wa.me/${waNumber}?text=${whatsappMsg}" target="_blank" rel="noopener noreferrer" class="product-card__image-link" aria-label="Pedir ${p.nombre} por WhatsApp"></a>`
        : '';

      const footerContent = !p.disponible
        ? `<p class="product-card__unavailable">Agotado</p>`
        : '';

      return `<li><article class="product-card"><div class="product-card__image-wrapper">${collageHtml}${badgeHtml}${imageLinkHtml}<div class="product-card__footer">${footerContent}</div></div><div class="product-card__body"><div class="product-card__name-row"><h3 class="product-card__name">${p.nombre}</h3></div><p class="product-card__description">${p.descripcion}</p></div></article></li>`;
    }).join('');

    grid.innerHTML = `<ul class="product-grid" role="list">${items}</ul>`;
  }
</script>
