---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductGrid from '../components/ProductGrid.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { CONFIG } from '../config.js';
import todosLosProductos from '../data/productos.json';

const categorias = [
  { id: 'todos', label: 'Todos' },
  { id: 'bolsos', label: 'Bolsos' },
  { id: 'llaveros', label: 'Llaveros' },
  { id: 'blusas', label: 'Blusas' },
  { id: 'moñas', label: 'Moñas' },
  { id: 'amigurumis', label: 'Amigurumis' },
  { id: 'manualidades', label: 'Manualidades' },
];
---

<BaseLayout
  title="Catálogo"
  description="Explora el catálogo de Eli Creaciones. Piezas a crochet hechas a mano: bolsos, llaveros, blusas, moñas, amigurumis y manualidades. Personalizaciones disponibles."
>
  <div class="catalogo-page">
    <div class="container">
      <header class="catalogo-page__header">
        <h1 class="catalogo-page__title">Nuestras creaciones</h1>
        <p class="catalogo-page__subtitle">
          Todas las piezas son hechas a mano y se pueden personalizar. ¿No encuentras lo que buscas? Escríbenos.
        </p>
      </header>

      <div class="catalogo-page__filters" role="tablist" aria-label="Filtrar por categoría">
        {categorias.map((cat) => (
          <button
            class="filter-btn"
            role="tab"
            data-categoria={cat.id}
            aria-selected={cat.id === 'todos' ? 'true' : 'false'}
          >
            {cat.label}
          </button>
        ))}
      </div>

      <div id="productos-grid">
        <ProductGrid productos={todosLosProductos} />
      </div>

      <div class="catalogo-page__custom">
        <div class="catalogo-page__custom-inner">
          <h2>¿Quieres algo personalizado?</h2>
          <p>Puedo hacer piezas a tu medida, en tus colores favoritos. ¡Escríbeme y lo hablamos!</p>
          <WhatsAppButton
            message={CONFIG.whatsapp.customMessage}
            label="Encargar pieza personalizada"
          />
        </div>
      </div>
    </div>
  </div>

  <WhatsAppButton variant="floating" />
</BaseLayout>

<style>
  .catalogo-page {
    padding-block: var(--space-16);
  }

  .catalogo-page__header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .catalogo-page__title {
    font-size: var(--text-4xl);
    font-weight: 700;
    margin-bottom: var(--space-4);
  }

  .catalogo-page__subtitle {
    font-size: var(--text-lg);
    color: var(--text-muted);
    max-width: 600px;
    margin-inline: auto;
  }

  .catalogo-page__filters {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    justify-content: center;
    margin-bottom: var(--space-12);
  }

  .filter-btn {
    padding: var(--space-2) var(--space-6);
    border-radius: 9999px;
    border: 2px solid var(--color-light);
    background-color: transparent;
    color: var(--text);
    font-size: var(--text-sm);
    font-weight: 500;
    cursor: pointer;
    transition: background-color 0.2s, border-color 0.2s, color 0.2s;
  }

  .filter-btn:hover,
  .filter-btn[aria-selected="true"] {
    background-color: var(--color-dark);
    border-color: var(--color-dark);
    color: white;
  }

  .catalogo-page__custom {
    margin-top: var(--space-24);
    padding: var(--space-12);
    background-color: var(--bg-secondary);
    border-radius: 16px;
    text-align: center;
  }

  .catalogo-page__custom-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    max-width: 540px;
    margin-inline: auto;
  }

  .catalogo-page__custom h2 {
    font-size: var(--text-2xl);
  }

  .catalogo-page__custom p {
    color: var(--text-muted);
  }
</style>

<script>
  import todosLosProductos from '../data/productos.json';

  const filterBtns = document.querySelectorAll('.filter-btn');
  const grid = document.getElementById('productos-grid');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterBtns.forEach((b) => b.setAttribute('aria-selected', 'false'));
      btn.setAttribute('aria-selected', 'true');

      const categoria = btn.getAttribute('data-categoria');
      const filtrados = categoria === 'todos'
        ? todosLosProductos
        : todosLosProductos.filter((p) => p.categoria === categoria);

      renderGrid(filtrados);
    });
  });

  function renderGrid(productos) {
    if (productos.length === 0) {
      grid.innerHTML = '<div class="product-grid__empty" style="text-align:center;padding:4rem 0;color:var(--text-muted);font-size:1.125rem;">No hay productos en esta categoría todavía.</div>';
      return;
    }

    const items = productos.map((p) => {
      const precio = new Intl.NumberFormat('es-CO', {
        style: 'currency',
        currency: 'COP',
        maximumFractionDigits: 0,
      }).format(p.precio);

      const imagenUrl = p.imagenes?.[0];
      const whatsappMsg = encodeURIComponent(`Hola! Vi tu página web y me interesa el/la ${p.nombre}. ¿Está disponible?`);
      const waNumber = '573142501765';

      const imgHtml = imagenUrl
        ? `<img src="${imagenUrl}" alt="${p.nombre} — Eli Creaciones" class="product-card__image" loading="lazy" width="400" height="500">`
        : `<div class="product-card__no-image" aria-label="Foto próximamente"><span>Foto próximamente</span></div>`;

      const badgeHtml = !p.disponible ? '<div class="product-card__badge">No disponible</div>' : '';

      const actionHtml = p.disponible
        ? `<a href="https://wa.me/${waNumber}?text=${whatsappMsg}" target="_blank" rel="noopener noreferrer" class="btn btn-whatsapp" aria-label="Pedir ${p.nombre} por WhatsApp"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>Pedir por WhatsApp</a>`
        : `<p class="product-card__unavailable">Por el momento no disponible — escríbenos si te interesa</p>`;

      return `<li><article class="product-card"><div class="product-card__image-wrapper">${imgHtml}${badgeHtml}</div><div class="product-card__body"><h3 class="product-card__name">${p.nombre}</h3><p class="product-card__description">${p.descripcion}</p><p class="product-card__price">${precio}</p>${actionHtml}</div></article></li>`;
    }).join('');

    grid.innerHTML = `<ul class="product-grid" role="list">${items}</ul>`;
  }
</script>
